# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# Flynet Discovery API key (sent as X-API-Key).
# SERVER-SIDE ONLY — never expose it to the browser.
# By default this app runs against production and returns real Blackbird
# restaurant and location data. Use a production key; to target staging instead,
# set the API_BASE_URL / AUTH_BASE_URL / AUTH_AUDIENCE vars below and swap in
# staging credentials. Request a key through the Flynet developer portal.
FLYNET_API_KEY=""

# OAuth client credentials (from provisioning). FLYNET_CLIENT_SECRET is backend-only.
# These power the "Sign in with Blackbird" flow: /api/auth/login starts the
# authorization-code + PKCE flow, /callback exchanges the code server-side, and
# the tokens live in HttpOnly cookies (refresh handled automatically).
FLYNET_CLIENT_ID=""
FLYNET_CLIENT_SECRET=""

# (Optional) Merchant id for Blackbird Pay, issued at production sign-off. When
# unset, the pay route falls back to paying off the member JWT (see
# app/api/pay/route.ts). Set it to route payment intents to your merchant.
FLYNET_MERCHANT_ID=""

# Must exactly match a redirect URI registered for your OAuth app.
# NOTE: the Blackbird edge blocks localhost/127.0.0.1 redirect URIs outright, so
# the sign-in flow can't run on a bare localhost URL. For local dev:
#   1. Run `flynet make` — the everyday tunnel command. It opens a tunnel to
#      your local app at a https://<subdomain>.local.make.flynet.org URL.
#   2. Whitelist https://<subdomain>.local.make.flynet.org/callback for your
#      OAuth app at https://make.flynet.org (sign in with your Slack email).
#   3. Set it here (e.g. https://<subdomain>.local.make.flynet.org/callback) and
#      open the app via the tunnel URL (not localhost), so the flow's cookies
#      land on the same host. Must be a full URL — leave blank to fall back to
#      localhost.
#   Fallback: if `flynet make` isn't available, use ngrok instead — first time
#   only, make a free account at https://dashboard.ngrok.com/signup and run
#   `ngrok config add-authtoken <token>`, then `ngrok http 3000` and whitelist
#   the https://<subdomain>.ngrok.app/callback URL the same way.
REDIRECT_URI=""

# (Optional) A member OAuth access token (JWT) with the read:profile and
# read:wallets scopes. Set it to skip the sign-in flow and pin the member
# section to this token — handy for quick API poking. Leave blank to use the
# sign-in flow above. Access tokens expire after 60 minutes.


# ── Environment (optional) ───────────────────────────────────────────────────
# Leave all three blank to target production (the app's default). Production is
# gated by partner approval and has its own credential set issued at sign-off
# (client id/secret, API key, redirect URI, merchant id). To target staging
# instead — useful for local development against test data — set:
#   API_BASE_URL="https://api.staging.blackbird.xyz/flynet/v1"
#   AUTH_BASE_URL="https://api.staging.blackbird.xyz/oauth"
#   AUTH_AUDIENCE="https://api-staging.blackbird.xyz/flynet"
# and swap every credential above for its staging counterpart.
